generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum RecommendationType {
  CAREER
  SKILLS
  COURSES
}

//////////////////////
// USER
//////////////////////

model User {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @db.VarChar(120)
  email             String             @unique @db.VarChar(255)
  passwordHash      String             @map("password_hash")
  role              UserRole           @default(USER)

  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  profile           Profile?
  skills            UserSkill[]
  careerPaths       UserCareerPath[]
  aiChats           AiChat[]
  recommendations   AiRecommendation[]
  progress          UserProgress[]
  resumes           Resume[]

  @@index([createdAt])
  @@map("users")
}

//////////////////////
// PROFILE (with image)
//////////////////////

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid

  bio             String?
  education       String?
  experienceLevel String?  @map("experience_level")
  careerGoal      String?  @map("career_goal")

  profileImage    String?  @map("profile_image") // ✅ profile picture

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([experienceLevel])
  @@map("profiles")
}

//////////////////////
// CATEGORY
//////////////////////

model Category {
  id      String   @id @default(uuid()) @db.Uuid
  name    String   @unique

  skills  Skill[]

  @@map("categories")
}

//////////////////////
// SKILLS
//////////////////////

model Skill {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  categoryId  String?     @map("category_id") @db.Uuid

  createdAt   DateTime    @default(now()) @map("created_at")

  category    Category?   @relation(fields: [categoryId], references: [id])
  users       UserSkill[]
  courses     Course[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@map("skills")
}

//////////////////////
// USER SKILLS
//////////////////////

model UserSkill {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  skillId   String   @map("skill_id") @db.Uuid

  level     Int      @db.SmallInt

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@map("user_skills")
}

//////////////////////
// CAREER PATHS (AI roadmap)
//////////////////////

model CareerPath {
  id          String           @id @default(uuid()) @db.Uuid
  title       String           @unique
  description String?

  roadmap     Json?            // ✅ AI generated roadmap

  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  users       UserCareerPath[]

  @@map("career_paths")
}

//////////////////////
// USER CAREER PATH
//////////////////////

model UserCareerPath {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  careerPathId String     @map("career_path_id") @db.Uuid

  progress     Decimal    @default(0) @db.Decimal(5,2)

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id])

  @@unique([userId, careerPathId])
  @@index([userId])
  @@index([careerPathId])
  @@map("user_career_paths")
}

//////////////////////
// COURSES
//////////////////////

model Course {
  id        String         @id @default(uuid()) @db.Uuid
  title     String
  provider  String
  url       String

  skillId   String         @map("skill_id") @db.Uuid

  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  skill     Skill          @relation(fields: [skillId], references: [id])
  progress  UserProgress[]

  @@index([skillId])
  @@map("courses")
}

//////////////////////
// USER PROGRESS
//////////////////////

model UserProgress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid

  completed Boolean  @default(false)
  progress  Decimal  @default(0) @db.Decimal(5,2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("user_progress")
}

//////////////////////
// AI CHAT
//////////////////////

model AiChat {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid

  message   String
  response  String

  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_chats")
}

//////////////////////
// AI RECOMMENDATIONS
//////////////////////

model AiRecommendation {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid

  type      RecommendationType
  content   Json

  createdAt DateTime           @default(now()) @map("created_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([createdAt])
  @@map("ai_recommendations")
}

//////////////////////
// RESUME CHECKER
//////////////////////

model Resume {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid

  fileUrl     String   @map("file_url")   // uploaded resume
  score       Int?     // AI score (0-100)
  feedback    Json?    // AI feedback

  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resumes")
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum UserRole {
  USER
  ADMIN
}

enum RecommendationType {
  CAREER
  SKILLS
  COURSES
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @db.VarChar(120)
  email             String             @unique @db.VarChar(255)
  passwordHash      String             @map("password_hash") @db.VarChar(255)
  role              UserRole           @default(USER)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile           Profile?
  userSkills        UserSkill[]
  userCareerPaths   UserCareerPath[]
  aiChats           AiChat[]
  aiRecommendations AiRecommendation[]
  userProgress      UserProgress[]

  @@index([createdAt], map: "idx_users_created_at")
  @@map("users")
}

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  bio             String?  @db.Text
  education       String?  @db.Text
  experienceLevel String?  @map("experience_level") @db.VarChar(50)
  careerGoal      String?  @map("career_goal") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([experienceLevel], map: "idx_profiles_experience_level")
  @@map("profiles")
}

model Skill {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  category  String?  @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  userSkills UserSkill[]
  courses   Course[]

  @@unique([name, category], map: "uq_skills_name_category")
  @@index([category], map: "idx_skills_category")
  @@map("skills")
}

model UserSkill {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  skillId   String   @map("skill_id") @db.Uuid
  level     Int      @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, skillId], map: "uq_user_skills_user_skill")
  @@index([userId], map: "idx_user_skills_user_id")
  @@index([skillId], map: "idx_user_skills_skill_id")
  @@map("user_skills")
}

model CareerPath {
  id          String           @id @default(uuid()) @db.Uuid
  title       String           @db.VarChar(160)
  description String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  users       UserCareerPath[]

  @@unique([title], map: "uq_career_paths_title")
  @@map("career_paths")
}

model UserCareerPath {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  careerPathId String     @map("career_path_id") @db.Uuid
  progress     Decimal    @default(0) @db.Decimal(5, 2)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, careerPathId], map: "uq_user_career_paths_user_path")
  @@index([userId], map: "idx_user_career_paths_user_id")
  @@index([careerPathId], map: "idx_user_career_paths_career_path_id")
  @@map("user_career_paths")
}

model AiChat {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  message   String   @db.Text
  response  String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, createdAt], map: "idx_ai_chats_user_created_at")
  @@map("ai_chats")
}

model AiRecommendation {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  type      RecommendationType
  content   Json
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, type], map: "idx_ai_recommendations_user_type")
  @@index([createdAt], map: "idx_ai_recommendations_created_at")
  @@map("ai_recommendations")
}

model Course {
  id        String         @id @default(uuid()) @db.Uuid
  title     String         @db.VarChar(200)
  provider  String         @db.VarChar(120)
  url       String         @db.VarChar(2048)
  skillId   String         @map("skill_id") @db.Uuid
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  skill     Skill          @relation(fields: [skillId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  progress  UserProgress[]

  @@index([skillId], map: "idx_courses_skill_id")
  @@index([provider], map: "idx_courses_provider")
  @@map("courses")
}

model UserProgress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  completed Boolean  @default(false)
  progress  Decimal  @default(0) @db.Decimal(5, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, courseId], map: "uq_user_progress_user_course")
  @@index([userId], map: "idx_user_progress_user_id")
  @@index([courseId], map: "idx_user_progress_course_id")
  @@map("user_progress")
}
